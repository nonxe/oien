# ‧₊˚ ☁️⋅♡ OIEN🪐 Config Template ♡⋅☁️ ࣪ ִֶָ☾.
# Copy this file to config.env and customize the variables for your local setup.
# Put your WhatsApp Session ID (obtained from session generator) in the SESSION variable.

# 🔑 AUTHENTICATION & DATA
# Session ID (e.g. RGNK~your_session_string)
SESSION=RGNK~

# Database connection. Default is SQLite (local ./bot.db) which is recommended for localhost.
# DATABASE_URL=./bot.db

# 🤖 BOT IDENTITY
BOT_NAME=OIEN🪐
STICKER_DATA=OIEN🪐
BOT_INFO=OIEN🪐;nonxe;default
ALIVE=‧₊˚ ☁️⋅♡𓂃 ࣪ ִֶָ☾.\n*OIEN🪐 IS ALIVE* 🦢˚. ᵎᵎ\n\nUptime: &uptime\nType *.menu* to see my commands!\n\n制造者: nonxe ♰ ⋆.˚
SUPPORT_GROUP=https://github.com/nonxe/oien

# 🛠️ SYSTEM & PORT
PORT=3000
USE_SERVER=true
LOG_LEVEL=silent
DEBUG=false
TZ=Asia/Kolkata

# 🎮 BASIC SETTINGS
MODE=private
HANDLERS=.,
MULTI_HANDLERS=false
LANGUAGE=english
AUTO_UPDATE=false

# 👤 ACCESS CONTROL
# Comma-separated list of phone numbers (excluding @s.whatsapp.net) with owner-level access
SUDO=
ADMIN_ACCESS=false
ALLOWED=91,94,2
NOT_ALLOWED=852
BLOCK_CHAT=

# 📖 AUTOMATED ACTIONS
READ_MESSAGES=false
READ_COMMAND=true
AUTO_READ_STATUS=false
ALWAYS_ONLINE=false
CMD_REACTION=false
AUTO_REACT=false
AUTO_STATUS_SEEN=false
AUTO_BIO=false
AUTO_TYPING=false
AUTO_RECORDING=false

# 🛡️ SECURITY & ANTI-SPAM
PM_ANTISPAM=false
PMB_VAR=false
DIS_PM=false
REJECT_CALLS=false
ANTI_BOT=
ANTI_DELETE=false
ANTILINK=false
ANTIBADWORD=false
ANTISPAM_COUNT=6/10
WARN=4

# 💬 REPLIES & WARNINGS
PMB=_Personal messages are not allowed, BLOCKED!_
AUTOMUTE_MSG=_Group automuted!_\n_(edit AUTOMUTE_MSG)_
AUTOUNMUTE_MSG=_Group auto unmuted!_\n_(edit AUTOUNMUTE_MSG)_
CALL_REJECT_MESSAGE=_Voice/Video calls are not allowed!_
ANTILINK_WARN=_Links are not allowed in this group!_
ANTIWORD_WARN=_Bad words are not allowed here!_

# 🔌 EXTERNAL APIs (OPTIONAL)
# Remove.bg API Key
RBG_KEY=
# Screenshot API Key
TAKE_KEY=
# Chatbot toggle (on/off)
CHATBOT=off
